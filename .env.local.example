# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is SECRET - server-side only, used to update statuses + send emails
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (resend.com -> API Keys)
RESEND_API_KEY=your-resend-api-key
# Must be a domain you've verified in Resend, e.g. requests@yourcompany.com
RESEND_FROM_EMAIL=requests@yourcompany.com

# Used in email links back to the dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000
